#!/usr/bin/env bash
# Boltz2 model cache + dev env bootstrap for Boltr (Rust inference).
#
# This downloads Boltz2 checkpoints into BOLTZ_CACHE, exports .safetensors, runs verify/tests,
# and writes boltr_go_bootstrap.json for boltr-web. It also installs the upstream Python `boltz`
# CLI into `.venv` by default (for `--preprocess boltz` / auto); set BOLTR_INSTALL_BOLTZ=0 to skip.
#
# From repo root:
#   chmod +x Boltr_Boltz_bootstrap && ./Boltr_Boltz_bootstrap
#   # Legacy alias: ./Boltr_go
#
# Uses POSIX [ tests so `sh ./Boltr_Boltz_bootstrap` works (no bash [[ required).
#
# Env:
#   BOLTZ_CACHE          - model cache (default: ~/.cache/boltr); same as boltr --cache-dir
#   CARGO_TARGET_DIR     - cargo build output (default: /tmp/boltr-target on /workspace systems)
#   BOLTR_GO_SKIP_TESTS  - set to 1 to skip cargo tests (faster iteration after first run)
#   BOLTR_GO_SKIP_VERIFY - set to 1 to skip verify_boltz2_safetensors (if checkpoint flags differ)
#   BOLTR_SKIP_SYSTEM_DEPS - set to 1 to skip Linux install of pkg-config / libssl-dev (see scripts/ensure_openssl_build_deps.sh)
#   BOLTR_INSTALL_BOLTZ      - set to 0 to skip pip install boltz into .venv (GPU-only separate env, etc.)
#   BOLTR_SKIP_RUSTUP    - set to 1 to skip auto-install/update of Rust via rustup

set -euo pipefail
ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT"

if [ -x "$HOME/.cargo/bin/cargo" ]; then
  export PATH="$HOME/.cargo/bin:$PATH"
fi

rust_version_ge() {
  # Usage: rust_version_ge CURRENT MINIMUM
  # Returns true when CURRENT >= MINIMUM. Requires coreutils sort -V.
  [ "$(printf '%s\n%s\n' "$2" "$1" | sort -V | head -n 1)" = "$2" ]
}

cargo_version() {
  cargo --version 2>/dev/null | awk '{print $2}'
}

ensure_rust_toolchain() {
  # Some transitive crates now use edition 2024, which requires Cargo/Rust >= 1.85.
  # Ubuntu 22.04's apt cargo can be older, so prefer rustup stable.
  min_rust="1.85.0"

  if [ "${BOLTR_SKIP_RUSTUP:-}" = "1" ]; then
    echo "==> Boltr_Boltz_bootstrap: skipping Rust auto-install (BOLTR_SKIP_RUSTUP=1)"
    return 0
  fi

  if command -v cargo >/dev/null 2>&1 && command -v rustc >/dev/null 2>&1; then
    current="$(cargo_version || true)"
    if [ -n "$current" ] && rust_version_ge "$current" "$min_rust"; then
      echo "==> Boltr_Boltz_bootstrap: Rust toolchain OK ($(cargo --version), $(rustc --version))"
      return 0
    fi
    echo "==> Boltr_Boltz_bootstrap: Cargo ${current:-unknown} is too old; installing/updating rustup stable"
  else
    echo "==> Boltr_Boltz_bootstrap: cargo/rustc not found; installing rustup stable"
  fi

  if command -v rustup >/dev/null 2>&1; then
    rustup toolchain install stable --profile minimal
    rustup default stable
  elif [ -x "$HOME/.cargo/bin/rustup" ]; then
    "$HOME/.cargo/bin/rustup" toolchain install stable --profile minimal
    "$HOME/.cargo/bin/rustup" default stable
  else
    export RUSTUP_INIT_SKIP_PATH_CHECK=yes
    if command -v curl >/dev/null 2>&1; then
      curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --profile minimal --default-toolchain stable
    elif command -v wget >/dev/null 2>&1; then
      wget -qO- https://sh.rustup.rs | sh -s -- -y --profile minimal --default-toolchain stable
    else
      echo "ERROR: need curl or wget to install Rust via rustup." >&2
      exit 1
    fi
  fi

  export PATH="$HOME/.cargo/bin:$PATH"
  hash -r 2>/dev/null || true

  if ! command -v cargo >/dev/null 2>&1 || ! command -v rustc >/dev/null 2>&1; then
    echo "ERROR: Rust installation finished, but cargo/rustc are still not on PATH." >&2
    exit 1
  fi

  current="$(cargo_version || true)"
  if [ -z "$current" ] || ! rust_version_ge "$current" "$min_rust"; then
    echo "ERROR: Cargo ${current:-unknown} is still too old; need >= $min_rust." >&2
    exit 1
  fi

  echo "==> Boltr_Boltz_bootstrap: Rust toolchain ready ($(cargo --version), $(rustc --version))"
}

ensure_rust_toolchain

if [ -z "${CARGO_TARGET_DIR:-}" ] && [ -d /workspace ]; then
  export CARGO_TARGET_DIR=/tmp/boltr-target
fi
if [ -n "${CARGO_TARGET_DIR:-}" ]; then
  mkdir -p "$CARGO_TARGET_DIR"
fi
TARGET_DIR="${CARGO_TARGET_DIR:-$ROOT/target}"

CACHE="${BOLTZ_CACHE:-$HOME/.cache/boltr}"
export BOLTZ_CACHE="$CACHE"
mkdir -p "$CACHE"
CONF_SF="$CACHE/boltz2_conf.safetensors"

echo "==> Boltr_Boltz_bootstrap: model cache directory: $CACHE"
if [ ! -f "$CACHE/boltz2_conf.ckpt" ] && [ ! -f "$CACHE/boltz2_conf.safetensors" ]; then
  echo "    (no boltz2 checkpoints in cache yet - bootstrap will download and export)"
elif [ -f "$CACHE/boltz2_conf.ckpt" ] && [ ! -f "$CONF_SF" ]; then
  echo "    (found .ckpt - bootstrap will export .safetensors if needed)"
else
  echo "    (cache already has boltz2 assets; bootstrap still runs download/export steps)"
fi

echo "==> Boltr_Boltz_bootstrap: prerequisite hints (non-fatal)"
bash scripts/check_tch_prereqs.sh || true

echo
echo "==> Boltr_Boltz_bootstrap: venv, build, download, Lightning -> safetensors, boltr doctor"
bash scripts/bootstrap_webui_env.sh

VERIFY_OK=0
VERIFY_SKIP=0
TESTS_OK=0
TESTS_SKIP=0

if [ "${BOLTR_GO_SKIP_VERIFY:-}" = "1" ]; then
  echo
  echo "==> Boltr_Boltz_bootstrap: skipping verify (BOLTR_GO_SKIP_VERIFY=1)"
  VERIFY_SKIP=1
elif [ ! -f "$CONF_SF" ]; then
  echo
  echo "==> Boltr_Boltz_bootstrap: VarStore verify skipped - missing $CONF_SF (re-run boltr download or export manually)" >&2
  VERIFY_SKIP=1
else
  echo
  echo "==> Boltr_Boltz_bootstrap: VarStore keys vs $CONF_SF"
  # Defaults match Boltz-2 trunk export; add --bond-type-feature / --blocks if your ckpt differs (DEVELOPMENT.md).
  scripts/cargo-tch run -p boltr-backend-tch --bin verify_boltz2_safetensors --features tch-backend -- "$CONF_SF"
  VERIFY_OK=1
fi

if [ "${BOLTR_GO_SKIP_TESTS:-}" != "1" ]; then
  echo
  echo "==> Boltr_Boltz_bootstrap: boltr-io tests (no LibTorch)"
  cargo test -p boltr-io

  echo
  echo "==> Boltr_Boltz_bootstrap: boltr-cli integration tests (default features; exercises predict/doctor/msa/tokens CLIs)"
  cargo test -p boltr-cli

  echo
  echo "==> Boltr_Boltz_bootstrap: boltr-backend-tch library tests (tch)"
  scripts/cargo-tch test -p boltr-backend-tch --features tch-backend --lib
  TESTS_OK=1
else
  echo
  echo "==> Boltr_Boltz_bootstrap: skipping tests (BOLTR_GO_SKIP_TESTS=1)"
  TESTS_SKIP=1
fi

echo
python3 "$ROOT/scripts/write_boltr_go_bootstrap_json.py" \
  --cache-dir "$CACHE" \
  --repo-root "$ROOT" \
  --download-ok 1 \
  --verify-ok "${VERIFY_OK:-0}" \
  --verify-skipped "${VERIFY_SKIP:-0}" \
  --tests-ok "${TESTS_OK:-0}" \
  --tests-skipped "${TESTS_SKIP:-0}"

echo
echo "Boltr_Boltz_bootstrap finished OK."
echo "  Status JSON: $CACHE/boltr_go_bootstrap.json (shown in boltr-web after Refresh status)"
echo "  boltr:     $TARGET_DIR/release/boltr"
echo "  boltr-web: $ROOT/scripts/run_boltr_web.sh"
echo "  export BOLTR=$TARGET_DIR/release/boltr   # optional if not using run_boltr_web.sh"
