# Copy to a private path and pass to the regression harness:
#   export BOLTR_REGRESSION_TOL_FILE=/path/to/regression_tol.env
#   BOLTR_REGRESSION=1 bash scripts/regression_compare_predict.sh input.yaml /tmp/out
#
# Or `set -a; source ./regression_tol.env; set +a` before running.

export BOLTR_COORD_RTOL=1e-3
export BOLTR_COORD_ATOL=1e-4
export BOLTR_PLDDT_RTOL=1e-3
export BOLTR_PLDDT_ATOL=1e-2
export BOLTR_PAE_RTOL=1e-3
export BOLTR_PAE_ATOL=1e-2
